# ScriptSense – Environment Variables Template
# -----------------------------------------------
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
#
# NEVER commit the real .env file to version control.

# ── Django ────────────────────────────────────────────────────────────────────
# A long, random secret string used for cryptographic signing.
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-django-secret-key-here

# Set to False in production!
DEBUG=True

# ── Groq AI API ───────────────────────────────────────────────────────────────
# Used by the Django backend for AI-powered grading & evaluation.
# Get a free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Used by the Teacher Vite frontend — MUST be prefixed with VITE_
# This should be the same key as GROQ_API_KEY above.
VITE_GROQ_API_KEY=gsk_your_groq_api_key_here

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Connection URI for the MongoDB instance.
# Default assumes MongoDB is running locally on the default port.
# For MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>
MONGO_URI=mongodb://localhost:27017

# ── Internal Service URLs ─────────────────────────────────────────────────────
# Base URLs used for internal Django-to-Django API calls.
# Only change these if you move Django to a non-default host or port.
OTHER_DJANGO_APP_URL=http://127.0.0.1:8000/evaluate/script/
OTHER_APP_URL=http://127.0.0.1:8000/student/feedback/
